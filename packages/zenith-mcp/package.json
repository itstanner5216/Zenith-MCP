{
  "name": "zenith-mcp",
  "version": "2026.1.14",
  "description": "Zenith-MCP filesystem server",
  "license": "MIT",
  "mcpName": "com.itstanner5216/zenith-mcp",
  "author": "Tanner",
  "homepage": "https://github.com/itstanner5216/Zenith-MCP",
  "bugs": "https://github.com/itstanner5216/Zenith-MCP/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/itstanner5216/Zenith-MCP.git"
  },
  "type": "module",
  "bin": {
    "zenith-mcp": "dist/cli/stdio.js",
    "zenith-mcp-http": "dist/server/http.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^26.3.0"
  },
  "scripts": {
    "clean": "shx rm -rf dist tsconfig.tsbuildinfo",
    "build": "node scripts/patch-mcp-server-dts.mjs && tsc --build && shx cp -r grammars dist/ && shx chmod +x dist/cli/*.js dist/server/*.js",
    "rebuild": "node scripts/patch-mcp-server-dts.mjs && tsc --build --force && shx cp -r grammars dist/ && shx chmod +x dist/cli/*.js dist/server/*.js",
    "watch": "node scripts/patch-mcp-server-dts.mjs && tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "start": "node dist/cli/stdio.js",
    "start:http": "node dist/server/http.js",
    "verify-grammar-pins": "node dist/scripts/verify-grammar-pins.js"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@iarna/toml": "^2.2.5",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@modelcontextprotocol/server": "2.0.0-beta.2",
    "@repomix/tree-sitter-wasms": "^0.1.17",
    "ajv": "^8.20.0",
    "diff": "^9.0.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "glob": "^13.0.6",
    "js-yaml": "^5.2.1",
    "json-schema-typed": "^8.0.2",
    "json5": "^2.2.3",
    "jsonc-parser": "^3.3.1",
    "minimatch": "^10.2.5",
    "web-tree-sitter": "^0.26.11",
    "zenith-toon": "workspace:*",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/emscripten": "^1.41.5",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "shx": "^0.4.0",
    "tree-sitter-cli": "^0.26.11",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
