{
  "name": "zenith-mcp",
  "version": "2026.1.14",
  "description": "Zenith-MCP filesystem server",
  "license": "MIT",
  "mcpName": "com.itstanner5216/zenith-mcp",
  "author": "Tanner",
  "homepage": "https://github.com/itstanner5216/Zenith-MCP",
  "bugs": "https://github.com/itstanner5216/Zenith-MCP/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/itstanner5216/Zenith-MCP.git"
  },
  "type": "module",
  "bin": {
    "zenith-mcp": "dist/cli/stdio.js",
    "zenith-mcp-http": "dist/server/http.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "clean": "shx rm -rf dist tsconfig.tsbuildinfo",
    "build": "tsc --build && shx cp -r grammars dist/ && shx chmod +x dist/cli/*.js dist/server/*.js",
    "rebuild": "tsc --build --force && shx cp -r grammars dist/ && shx chmod +x dist/cli/*.js dist/server/*.js",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "start": "node dist/cli/stdio.js",
    "start:http": "node dist/server/http.js"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@iarna/toml": "^2.2.5",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@modelcontextprotocol/server": "2.0.0-alpha.2",
    "@repomix/tree-sitter-wasms": "^0.1.17",
    "@workos-inc/authkit-js": "^0.20.0",
    "@workos-inc/node": "^9.3.1",
    "ajv": "^8.17.1",
    "diff": "^5.1.0",
    "express": "^5.2.1",
    "glob": "^10.5.0",
    "js-yaml": "^4.1.0",
    "json-schema-typed": "^8.0.2",
    "json5": "^2.2.3",
    "jsonc-parser": "^3.3.1",
    "minimatch": "^10.0.1",
    "web-tree-sitter": "^0.26.8",
    "workos": "^0.15.2",
    "zenith-toon": "workspace:*",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/diff": "^5.0.9",
    "@types/emscripten": "^1.41.5",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.5",
    "shx": "^0.3.4",
    "tree-sitter-cli": "^0.26.8",
    "typescript": "^5.8.2",
    "vitest": "^4.1.5"
  }
}