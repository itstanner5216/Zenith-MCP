{
  "name": "zenith-mcp",
  "version": "2026.1.14",
  "description": "Zenith-MCP filesystem server",
  "license": "MIT",
  "mcpName": "com.itstanner5216/zenith-mcp",
  "author": "Tanner",
  "homepage": "https://github.com/itstanner5216/Zenith-MCP",
  "bugs": "https://github.com/itstanner5216/Zenith-MCP/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/itstanner5216/Zenith-MCP.git"
  },
  "bin": {
    "zenith-mcp": "node --env-file-if-exists=/home/tanner/mcp-servers/.env packages/zenith-mcp/dist/server/http.js"
  },
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "clean": "pnpm -r --filter zenith-toon --filter zenith-mcp run clean",
    "build": "pnpm -r --filter zenith-toon --filter zenith-mcp run build",
    "rebuild": "pnpm -r --filter zenith-toon --filter zenith-mcp run rebuild",
    "build:toon": "pnpm --filter zenith-toon run build",
    "build:mcp": "pnpm --filter zenith-mcp run build",
    "rebuild:toon": "pnpm --filter zenith-toon run rebuild",
    "rebuild:mcp": "pnpm --filter zenith-mcp run rebuild",
    "build:turbo": "turbo run build",
    "test": "pnpm --filter zenith-mcp run test",
    "test:turbo": "turbo run test --filter=zenith-mcp",
    "start": "pnpm --env-file-if-exists=/home/tanner/mcp-servers/.env filter zenith-mcp run start",
    "dev": "turbo run dev",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2.9.16",
    "typescript": "^5.9.3"
  }
}
