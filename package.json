{
  "name": "zenith",
  "version": "2026.1.14",
  "private": true,
  "description": "Zenith-MCP monorepo",
  "type": "module",
  "main": "packages/zenith-mcp/src/server/http.ts",
  "license": "MIT",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "clean": "pnpm -r --filter zenith-toon --filter zenith-mcp run clean",
    "build": "pnpm -r --filter zenith-toon --filter zenith-mcp run build",
    "rebuild": "pnpm -r --filter zenith-toon --filter zenith-mcp run rebuild",
    "build:toon": "pnpm --filter zenith-toon run build",
    "build:mcp": "pnpm --filter zenith-mcp run build",
    "rebuild:toon": "pnpm --filter zenith-toon run rebuild",
    "rebuild:mcp": "pnpm --filter zenith-mcp run rebuild",
    "build:turbo": "turbo run build",
    "test": "pnpm --dir packages/zenith-mcp exec vitest run",
    "test:toon": "pnpm --filter zenith-toon run test",
    "test:turbo": "turbo run test --filter=zenith-mcp",
    "start": "pnpm --filter zenith-mcp run start",
    "start:http": "pnpm --filter zenith-mcp run start:http",
    "dev": "turbo run dev",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2.9.18",
    "typescript": "^6.0.3"
  }
}
