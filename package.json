{
  "name": "zenith-mcp",
  "version": "2026.1.14",
  "description": "Zenith-MCP filesystem server",
  "license": "MIT",
  "mcpName": "com.itstanner5216/zenith-mcp",
  "author": "Tanner",
  "homepage": "https://github.com/itstanner5216/Zenith-MCP",
  "bugs": "https://github.com/itstanner5216/Zenith-MCP/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/itstanner5216/Zenith-MCP.git"
  },
  "type": "module",
  "bin": {
    "zenith-mcp": "dist/index.js",
    "zenith-mcp-http": "dist/http-server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "shx chmod +x dist/*.js",
    "prepare": "npm run build",
    "watch": "node -e \"console.log('Zenith-MCP uses a dist-only layout right now; no TypeScript watch step is configured.')\"",
    "test": "vitest run --coverage",
    "start": "node dist/index.js",
    "start:http": "node dist/http-server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "diff": "^5.1.0",
    "express": "^5.2.1",
    "glob": "^10.5.0",
    "minimatch": "^10.0.1",
    "web-tree-sitter": "^0.26.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/diff": "^5.0.9",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^22",
    "@vitest/coverage-v8": "^2.1.8",
    "shx": "^0.3.4",
    "typescript": "^5.8.2",
    "vitest": "^2.1.8"
  }
}
